{
    "FL":{
        "num_clients": 25,
        "sample_ratio": 1.0,
        "num_rounds": 100,
        "checkpoint_step":10
    },
    "target_dataset":{
        "name": "webqa",
        "dev_rate": 0.1,
        "frequency":true
    },
    "poison_dataset":{
        "name": "webqa",
        "dev_rate": 0.1,
        "frequency":true
    },
    "victim":{
        "type": "casual",
        "model": "vicuna",
        "path": "../models/vicuna-7b-v1.5-16k",
        "device": "gpu",
        "update_lm_head":false,
        "max_len": 1024,
        "peftConfig":{
            "lora":true,
            "loraConfig": {
                "lora_alpha": 8,
                "lora_dropout": 0.0,
                "r": 4
            }
        }
    },
    "attacker":{
        "name": "base",
        "metrics": ["emr", "kmr"],
        "attack_setting": "iid",
        "train":{
            "name": "casual",
            "lr": 2e-5,
            "weight_decay": 0,
            "max_grad_norm":1.0,
            "epochs": 1,
            "batch_size": 4,
            "warm_up_epochs": 0,
            "gradient_accumulation_steps":1,
            "ckpt": "best",
            "save_path": "./models",
            "attackMethod":"generativebadnets"
        },
        "poisoner":{
            "name": "generativebadnets",
            "poisonComponent":"question",
            "poison_rate": 0.1,
            "targetReplaced":false,
            "load": false,
            "save":false,
            "triggers": ["cf", "mn", "bb", "tq"],
            "targetOutput": ", and click <malicious_url> for more information",
            "label_consistency": false,
            "label_dirty": false,
            "target_label":-1
        }
    },
    "clean-tune": false
}

